{
  "task": "face_recognition",
  "description": "Identify person from registered faces (1:N matching)",
  "response_fields": {
    "person_id": {
      "type": "string",
      "description": "Matched person ID from database",
      "example": "emp_001"
    },
    "name": {
      "type": "string",
      "description": "Person name",
      "example": "John Doe"
    },
    "confidence": {
      "type": "float",
      "description": "Match similarity score (0.0 to 1.0)",
      "example": 0.92
    },
    "executed_at": {
      "type": "integer",
      "description": "Timestamp in milliseconds when inference was executed",
      "example": 1735546430000
    },
    "latency_ms": {
      "type": "integer",
      "description": "Inference latency in milliseconds",
      "example": 60
    }
  },
  "example_response": {
    "person_id": "emp_001",
    "name": "John Doe",
    "confidence": 0.92,
    "executed_at": 1735546430000,
    "latency_ms": 60
  }
}
